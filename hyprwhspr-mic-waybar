#!/bin/bash
# Waybar module for hyprwhspr with mic name display and switching.
#
# Usage (in Waybar module config):
#   exec:            hyprwhspr-mic-waybar status
#   on-click:        hyprwhspr-mic-waybar menu
#
# Config: ~/.config/hyprwhspr-mic/config.json
#   mic_labels   - object mapping source name substrings to friendly labels
#   mute_others  - true/false, toggled via menu

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/hyprwhspr-mic-common"

TRAY_SCRIPT="/usr/lib/hyprwhspr/config/hyprland/hyprwhspr-tray.sh"

# Map PulseAudio source names to friendly labels.
# Checks config file first, falls back to built-in defaults.
mic_label() {
  local source="$1"

  # Try config-based labels
  if [[ -f "$CONFIG_FILE" ]]; then
    local label
    label=$(jq -r --arg src "$source" '
      .mic_labels // {} | to_entries[] |
      select($src | test(.key)) | .value
    ' "$CONFIG_FILE" 2>/dev/null | head -1)
    if [[ -n "$label" ]]; then
      echo "$label"
      return
    fi
  fi

  # Fallback defaults
  case "$source" in
    *StreamCam*)    echo "StreamCam" ;;
    *analog-stereo) echo "Headset" ;;
    *)              echo "$source" ;;
  esac
}

# Get the next available mic source name (not the current one)
next_mic_source() {
  local sources current
  sources=($(pactl list short sources | grep -v monitor | awk '{print $2}'))
  [[ ${#sources[@]} -lt 2 ]] && return 1
  current="$(pactl get-default-source)"
  for s in "${sources[@]}"; do
    [[ "$s" != "$current" ]] && { echo "$s"; return; }
  done
}

# Switch default source to the next available mic
do_switch() {
  local other
  other=$(next_mic_source) || return 1
  pactl set-default-source "$other"
}

# Toggle a boolean config key in config.json
toggle_cfg() {
  local key="$1"
  local current
  current=$(cfg "$key" true)
  local new_val
  [[ "$current" == "true" ]] && new_val=false || new_val=true

  if [[ -f "$CONFIG_FILE" ]]; then
    local tmp
    tmp=$(jq --arg k "$key" --argjson v "$new_val" '.[$k] = $v' "$CONFIG_FILE")
    echo "$tmp" > "$CONFIG_FILE"
  fi
}

# Show fuzzel menu anchored below the waybar
do_menu() {
  local default_source label mute_state mute_label next_source next_label switch_label
  default_source="$(pactl get-default-source 2>/dev/null)"
  label="$(mic_label "$default_source")"
  mute_state="$(cfg mute_others true)"
  [[ "$mute_state" == "true" ]] && mute_label="Mute others: ON" || mute_label="Mute others: OFF"
  next_source=$(next_mic_source 2>/dev/null)
  next_label="$(mic_label "${next_source:-}")"
  switch_label="Switch mic to $next_label"

  # Check if hyprwhspr service is active
  local svc_active svc_label
  if systemctl --user is-active hyprwhspr.service &>/dev/null; then
    svc_label="Deactivate hyprwhspr"
  else
    svc_label="Activate hyprwhspr"
  fi

  # Position menu under the cursor, relative to the focused monitor.
  local cursor_x mon_x mon_w rel_x menu_w x_margin
  cursor_x=$(hyprctl cursorpos 2>/dev/null | cut -d, -f1 | tr -d ' ')
  eval "$(hyprctl monitors -j 2>/dev/null | jq -r \
    --argjson cx "${cursor_x:-0}" '
    .[] | select(.x <= $cx and $cx < (.x + .width)) |
    "mon_x=\(.x) mon_w=\(.width)"' | head -1)"
  rel_x=$(( cursor_x - ${mon_x:-0} ))
  menu_w=300
  # center menu on cursor, clamp to screen edges
  x_margin=$(( rel_x - menu_w / 2 ))
  (( x_margin < 0 )) && x_margin=0
  (( x_margin + menu_w > ${mon_w:-3840} )) && x_margin=$(( ${mon_w:-3840} - menu_w ))

  local choice
  choice=$(printf '%s\n' \
    "Record" \
    "$switch_label" \
    "$mute_label" \
    "$svc_label" \
    "Restart service" \
    | fuzzel --dmenu \
        --anchor top-left \
        --x-margin "${x_margin}" \
        --y-margin 30 \
        --font "monospace:size=9" \
        --lines 5 \
        --width 25 \
        --no-icons \
        --prompt "hyprwhspr > " \
        --background-color 1e1e2eff \
        --text-color cdd6f4ff \
        --selection-color 45475aff \
        --selection-text-color cdd6f4ff \
        --match-color f38ba8ff \
        --border-color 6c7086ff \
        --border-width 2 \
        --border-radius 8 \
        --prompt-color 89b4faff)

  case "$choice" in
    Record*)              "$SCRIPT_DIR/hyprwhspr-mic" record ;;
    "Switch mic"*)         do_switch ;;
    "Mute others"*)       toggle_cfg mute_others ;;
    "Deactivate"*)        systemctl --user stop hyprwhspr.service ;;
    "Activate"*)          systemctl --user start hyprwhspr.service ;;
    "Restart service"*)   "$TRAY_SCRIPT" restart ;;
  esac
}

case "${1:-status}" in
  menu)
    do_menu
    ;;
  switch)
    do_switch
    exec "$0" status
    ;;
  record)
    "$SCRIPT_DIR/hyprwhspr-mic" record
    exec "$0" status
    ;;
  restart)
    "$TRAY_SCRIPT" restart
    exec "$0" status
    ;;
  toggle-mute)
    toggle_cfg mute_others
    exec "$0" status
    ;;
  *)
    # If hyprwhspr service is not running, show a static "down" status
    if ! systemctl --user is-active hyprwhspr.service &>/dev/null; then
      echo '{"text":"hyprwhspr down","tooltip":"hyprwhspr service is not running","class":"inactive"}'
      exit 0
    fi

    # Get original JSON from hyprwhspr-tray.sh
    json=$("$TRAY_SCRIPT" "$@")

    # Get current mic label
    default_source="$(pactl get-default-source 2>/dev/null)"
    label="$(mic_label "$default_source")"

    # Read mute setting
    mute_state="$(cfg mute_others true)"
    [[ "$mute_state" == "true" ]] && mute_display="on" || mute_display="off"

    # Inject mic label into text field (append after icon)
    # and add mic info to tooltip
    if [[ -n "$label" && -n "$json" ]]; then
      json=$(echo "$json" | sed \
        -e "s/\"text\":\"\([^\"]*\)\"/\"text\":\"\1 $label\"/" \
        -e "s/\"tooltip\":\"\([^\"]*\)\"/\"tooltip\":\"Active mic: $label\\\\nMute others: $mute_display\\\\n\\\\n\1\"/")
    fi

    echo "$json"
    ;;
esac
