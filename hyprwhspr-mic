#!/bin/bash
# Wrapper around hyprwhspr recording that manages mic access for other apps.
#
# Usage:
#   hyprwhspr-mic record       # toggle recording (English)
#   hyprwhspr-mic record de    # toggle recording (German)
#
# On start: optionally set mic volume and mute other apps' source-outputs, then record.
# On stop:  stop recording, then unmute all source-outputs.
#
# Config: ~/.config/hyprwhspr-mic/config.json
#   mute_others          - true/false (default: true)
#   reset_volume         - true/false (default: true)
#   reset_volume_percent - integer    (default: 100)

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/hyprwhspr-mic-common"

RECORDING_CONTROL="$HOME/.config/hyprwhspr/recording_control"
OWN_STATE="/tmp/hyprwhspr-mute-state"

is_recording() {
  [[ "$(cat "$OWN_STATE" 2>/dev/null)" == "recording" ]]
}

get_hyprwhspr_pid() {
  systemctl --user show hyprwhspr.service --property=MainPID --value 2>/dev/null
}

mute_others() {
  if [[ "$(cfg reset_volume true)" == "true" ]]; then
    local pct
    pct=$(cfg reset_volume_percent 100)
    pactl set-source-volume @DEFAULT_SOURCE@ "${pct}%"
  fi

  if [[ "$(cfg mute_others true)" != "true" ]]; then
    return
  fi

  local hwpid
  hwpid=$(get_hyprwhspr_pid)

  # Mute all source-outputs except those belonging to hyprwhspr
  pactl -f json list source-outputs 2>/dev/null \
    | jq -r --arg pid "$hwpid" \
        '.[] | select(.properties."application.process.id" != $pid) | .index' \
    | while read -r id; do
        [[ -n "$id" ]] && pactl set-source-output-mute "$id" 1 2>/dev/null
      done
}

unmute_others() {
  if [[ "$(cfg mute_others true)" != "true" ]]; then
    return
  fi

  # Unmute ALL source-outputs — indices are ephemeral in PipeWire so
  # replaying saved indices is unreliable.
  pactl -f json list source-outputs 2>/dev/null \
    | jq -r '.[].index' \
    | while read -r id; do
        [[ -n "$id" ]] && pactl set-source-output-mute "$id" 0 2>/dev/null
      done
}

case "${1:-}" in
  record)
    if is_recording; then
      # Stop recording, then unmute
      echo stop > "$RECORDING_CONTROL"
      unmute_others
      echo "stopped" > "$OWN_STATE"
    else
      # Mute others first, then start recording
      mute_others
      echo "recording" > "$OWN_STATE"
      if [[ -n "${2:-}" ]]; then
        echo "start:$2" > "$RECORDING_CONTROL"
      else
        echo start > "$RECORDING_CONTROL"
      fi
    fi
    ;;
  *)
    echo "Usage: $0 record [LANG]"
    exit 1
    ;;
esac
